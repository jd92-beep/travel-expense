{
  "name": "travel-expense-compact",
  "private": true,
  "version": "0.19.3",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 8903",
    "build": "vite build",
    "build:pages": "VITE_BASE_PATH=/travel-expense/compact/ npm run build",
    "build:root": "VITE_BASE_PATH=/ npm run build",
    "android:sync": "npm run build:root && cap sync android",
    "android:debug": "node scripts/run-with-android-jdk.mjs --npm-script android:debug:raw",
    "android:debug:raw": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:bundle": "npm run android:sync && cd android && ./gradlew bundleRelease",
    "android:open": "cap open android",
    "android:qa": "node scripts/run-with-android-jdk.mjs --npm-script android:qa:raw",
    "android:qa:raw": "node scripts/android-qa-smoke.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4175",
    "typecheck": "tsc --noEmit",
    "test:receipt-tombstone": "node --experimental-strip-types scripts/receipt-tombstone.test.ts",
    "test:itinerary-merge": "node scripts/run-itinerary-sync-merge-test.mjs",
    "test:android-jdk": "node scripts/run-with-android-jdk.mjs --self-test",
    "test:split-engine": "node --experimental-strip-types scripts/split-engine.test.ts",
    "test:notion-split-meta": "node --experimental-strip-types scripts/notion-split-meta.test.ts",
    "parity:tabs": "node ../scripts/tab-parity.mjs",
    "security:scan": "node ../scripts/security-scan.mjs",
    "db:policy:scan": "node ../scripts/verify-supabase-migrations.mjs",
    "db:rls:smoke": "node ../scripts/run-rls-smoke.mjs",
    "smoke:ai-routing": "playwright test tests/ai-routing-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:auth-broker": "playwright test tests/auth-broker-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:history": "playwright test tests/history-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:dashboard": "playwright test tests/dashboard-parity-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:scan": "playwright test tests/scan-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:split-editor": "playwright test tests/split-editor-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:timeline": "playwright test tests/timeline-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:itinerary": "playwright test tests/itinerary-edit-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:weather": "playwright test tests/weather-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:privacy": "playwright test tests/receipt-privacy-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:offline": "playwright test tests/offline-sync-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:session": "playwright test tests/session-persistence-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:sync-classify": "playwright test tests/sync-error-classify-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:stats": "playwright test tests/stats-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:six-person": "playwright test tests/six-person-share-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:settle-up": "node scripts/run-with-dev-server.mjs -- ./node_modules/.bin/playwright test tests/settle-up-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:settings": "playwright test tests/settings-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:welcome-guide": "playwright test tests/welcome-guide-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:a11y-touch": "playwright test tests/a11y-touch-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:security": "node scripts/run-with-dev-server.mjs -- playwright test tests/security-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:supabase-notion-mirror": "playwright test tests/supabase-notion-mirror-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:supabase-backfill": "playwright test tests/supabase-backfill-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:broker-live": "node scripts/broker-live-preflight.mjs",
    "smoke:android-broker-origin": "node scripts/android-broker-origin-smoke.mjs",
    "broker-vault:prepare": "node scripts/broker-vault-prepare.mjs",
    "smoke:broker-vault": "node scripts/broker-vault-verify.mjs",
    "smoke:broker-vault:doctor": "node scripts/broker-vault-doctor.mjs",
    "smoke:broker-vault:guard": "node scripts/broker-vault-verify.mjs --expect-missing-session",
    "smoke:trip-update-live": "node scripts/trip-update-live-smoke.mjs",
    "smoke:shared-contract": "node scripts/shared-contract-smoke.mjs",
    "smoke:shared-ledger": "node ../scripts/verify-shared-ledger-contract.mjs",
    "smoke:production-gate": "node scripts/compact-production-gate.mjs",
    "smoke:production-gate:full": "node scripts/compact-production-gate.mjs --full",
    "smoke:deploy-live": "node scripts/compact-live-verify.mjs",
    "smoke:live-checklist": "node scripts/compact-live-regression-checklist.mjs",
    "smoke:live-checklist:strict": "node scripts/compact-live-regression-checklist.mjs --strict",
    "smoke:mobile-layout": "playwright test tests/mobile-layout-stability-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:contact-sheet": "node scripts/mobile-contact-sheet.mjs",
    "smoke:final-nav": "playwright test tests/final-navigation-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:trip-intelligence": "playwright test tests/trip-intelligence-smoke.spec.cjs --workers=1 --browser=chromium --reporter=line"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@supabase/supabase-js": "^2.106.2",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.16"
  }
}
