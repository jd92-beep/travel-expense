// Local dev secrets — desktop testing only.
//
// Copy this file to `secrets.local.js` (gitignored) and fill in real keys.
// index.html reads `window.DEV_SECRETS` at load time and uses it only when
// nothing else is configured. On the deployed GitHub Pages site this file
// doesn't exist → DEV_SECRETS is undefined → the app falls back to
// Settings → 🔑 API Keys user input.
//
// Sources for real values (on this machine):
//   ~/.openclaw/agents/main/agent/auth-profiles.json
//     profiles["minimax-portal:default"].access  → minimaxKey
//     profiles["zai:default"].key                → zaiKey
//   ~/.openclaw/credentials/oauth.json           (if present, newer token)
//   Kimi for Coding key:  https://platform.kimi.ai  (sk-kimi-... prefix)
//
// IMPORTANT: if you commit this file by mistake, rotate all tokens
// immediately at:
//   MiniMax portal  https://platform.minimaxi.com
//   Zhipu (ZAI)     https://open.bigmodel.cn
//   Kimi             https://platform.kimi.ai
window.DEV_SECRETS = {
  minimaxKey: 'sk-cp-REPLACE_WITH_MINIMAX_PORTAL_ACCESS_TOKEN',
  zaiKey: 'REPLACE_WITH_ZAI_API_KEY',
  kimiKey: 'sk-kimi-REPLACE_WITH_KIMI_KEY',
};
