// Local dev secrets — desktop testing only.
//
// Copy this file to `secrets.local.js` (gitignored) and fill in real keys.
// index.html reads `window.DEV_SECRETS` at load time and uses it only when
// nothing else is configured.
//
// On the deployed GitHub Pages site, keys come from GitHub repository secrets
// (Settings → Secrets and variables → Actions), NOT from this file.
// The deploy.yml workflow injects them at build time via sed replacement of
// __MINIMAX_KEY__ / __ZAI_KEY__ / __KIMI_KEY__ placeholders.
//
// Where to get real values:
//   MiniMax  → https://platform.minimaxi.com  (sk-cp-... prefix)
//   ZAI/GLM  → https://open.bigmodel.cn       (32hex.base62 format)
//   Kimi     → https://platform.kimi.ai        (sk-kimi-... prefix)
//
// IMPORTANT: if you commit this file by mistake, rotate all tokens immediately.
window.DEV_SECRETS = {
  minimaxKey: 'sk-cp-REPLACE_WITH_MINIMAX_PORTAL_ACCESS_TOKEN',
  zaiKey: 'REPLACE_WITH_ZAI_API_KEY',
  kimiKey: 'sk-kimi-REPLACE_WITH_KIMI_KEY',
};
