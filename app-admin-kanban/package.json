{
  "name": "travel-expense-admin-kanban",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 8904",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "security:scan": "node scripts/security-scan.mjs",
    "test:unit": "node --test tests/server/health.test.js tests/server/readiness.test.js tests/server/cookies.test.js tests/server/crypto.test.js tests/server/passkeys.test.js tests/server/session.test.js tests/server/webauthn.test.js tests/server/vercel-function-count.test.js tests/server/vercel-protected-request.test.js tests/server/deploy-production.test.js",
    "test:contract": "node --test tests/server/edge.test.js tests/server/gateway-routes.test.js tests/admin-routes.test.js tests/admin-bff-integration.test.js",
    "smoke": "playwright test --config playwright.config.cjs --workers=1 --browser=chromium --reporter=line",
    "smoke:mobile": "playwright test --config playwright.config.cjs --workers=1 --browser=chromium --reporter=line --grep mobile",
    "smoke:a11y": "playwright test --config playwright.config.cjs --workers=1 --browser=chromium --reporter=line --grep axe",
    "deploy": "node scripts/deploy-production.mjs"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.18.1",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.0"
  }
}
